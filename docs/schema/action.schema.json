              "neoorigins:if_else",
              "neoorigins:damage",
              "neoorigins:heal",
              "neoorigins:feed",
              "neoorigins:exhaust",
              "neoorigins:gain_air",
              "neoorigins:apply_effect",
              "neoorigins:clear_effect",
              "neoorigins:add_velocity",
              "neoorigins:launch",
              "neoorigins:give",
              "neoorigins:execute_command",
              "neoorigins:play_sound",
              "neoorigins:spawn_entity",
              "neoorigins:spawn_projectile",
