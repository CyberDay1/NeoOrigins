              "origins:spawn_entity",
              "apace:spawn_entity",
              "origins:spawn_projectile",
              "apace:spawn_projectile",
              "origins:area_of_effect",
              "apace:area_of_effect",
              "origins:grant_power",
              "origins:revoke_power",
              "neoorigins:toggle",
              "neoorigins:add_to_set",
